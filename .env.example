# ServiceNow Instance (Sandbox/PDI only – NEVER production)
# These are the legacy single-instance variables. They still work as a fallback
# when sn_instances.json is not configured or an instance key is not specified.
SN_INSTANCE=https://dev12345.service-now.com
SN_USER=ai_config_bot
SN_PASSWORD=changeme

# Local Git repository for Update Set XML exports
GIT_REPO_PATH=/path/to/your/git/repo

# Per-instance passwords for CI/CD pipeline (used with sn_instances.json)
# The service account username is shared and configured in sn_instances.json.
# Each instance has its own password env var.
SN_SANDBOX_PASSWORD=changeme
SN_DEV_PASSWORD=changeme
SN_TEST_PASSWORD=changeme
SN_PROD_PASSWORD=changeme
